{
  "task": {
    "id": "seed/02-reverse",
    "prompt": "Write a function `reverse(s)` that returns the input string reversed.",
    "tests": [
      {"id": "seed/02-reverse/t0", "code": "assert reverse('hello') == 'olleh'"},
      {"id": "seed/02-reverse/t1", "code": "assert reverse('') == ''"},
      {"id": "seed/02-reverse/t2", "code": "assert reverse('a') == 'a'"},
      {"id": "seed/02-reverse/t3", "code": "assert reverse('racecar') == 'racecar'"},
      {"id": "seed/02-reverse/t4", "code": "assert reverse('123 456') == '654 321'"},
      {"id": "seed/02-reverse/t5", "code": "assert reverse('AbC') == 'CbA'"}
    ]
  },
  "gold_spec": {
    "goal": "Return the input string with its code points in reverse order.",
    "inputs": [
      {"name": "s", "type": "str", "description": "the string to reverse", "constraints": []}
    ],
    "outputs": [
      {"name": "result", "type": "str", "description": "code-point reversal of s", "constraints": ["len(result) == len(s)"]}
    ],
    "preconditions": ["s is a str"],
    "postconditions": ["result == s[::-1]"],
    "invariants": [],
    "edge_cases": [
      "empty string returns empty string",
      "Unicode strings: reverse code points, not graphemes (multi-codepoint emoji clusters may visually corrupt — this is acceptable)",
      "preserves case and whitespace exactly"
    ],
    "acceptance_criteria": [
      "result equals s[::-1] for any str input",
      "no normalization, lowercasing, or whitespace stripping"
    ]
  }
}
